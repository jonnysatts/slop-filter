# Runtime
PORT=8743
SLOPFILTER_HOST=0.0.0.0
SLOPFILTER_PORT=8743
SLOPFILTER_DATA_DIR=/data/slopfilter
SLOPFILTER_MAX_REQUEST_BYTES=512000

# API security
# Use either one key or a comma-separated list.
SLOPFILTER_API_KEY=
# SLOPFILTER_API_KEYS=key-one,key-two

# CORS
# Comma-separated allowlist. Leave empty for local development.
SLOPFILTER_ALLOWED_ORIGINS=https://your-netlify-site.netlify.app,https://jobseeker.yourdomain.com

# Future Supabase rollout
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_STORAGE_BUCKET=slopfilter-exports
